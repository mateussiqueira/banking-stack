# ─── Ports ─────────────────────────────────────────────────────────────

# Infrastructure
MONGO_PORT=27017
REDIS_PORT=6379
POSTGRES_PORT=5432
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# Backend services
LEDGER_PORT=3000
SPI_SIMULATOR_PORT=3001
DICT_SIMULATOR_PORT=3002
ISO8583_PORT=3003
WORKFLOW_ENGINE_PORT=3004
OPEN_FINANCE_PORT=3005
NFSE_PORT=3006
REPORT_SYSTEM_PORT=3007
LEAKY_BUCKET_PORT=3008

# Frontend services
LANDING_PAGE_PORT=5173
KYC_SYSTEM_PORT=5174

# ─── MongoDB ──────────────────────────────────────────────────────────

MONGO_ROOT_USER=admin
MONGO_ROOT_PASSWORD=mongo_secret_2024
MONGODB_URI=mongodb://admin:mongo_secret_2024@localhost:27017/banking_challenges?authSource=admin&replicaSet=rs0

# ─── Redis ────────────────────────────────────────────────────────────

REDIS_PASSWORD=redis_secret_2024
REDIS_URI=redis://:redis_secret_2024@localhost:6379

# ─── PostgreSQL ───────────────────────────────────────────────────────

POSTGRES_DB=banking_challenges
POSTGRES_USER=banking
POSTGRES_PASSWORD=postgres_secret_2024
POSTGRES_URI=postgresql://banking:postgres_secret_2024@localhost:5432/banking_challenges

# ─── MinIO (S3-compatible) ────────────────────────────────────────────

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minio_secret_2024
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minio_secret_2024
MINIO_REPORT_BUCKET=banking-reports
MINIO_REGION=us-east-1
MINIO_USE_SSL=false

# ─── Application ──────────────────────────────────────────────────────

NODE_ENV=development
LOG_LEVEL=debug

# ─── Encryption / Auth (shared across all services) ────────────────────

JWT_SECRET=change-me-to-a-random-64-char-string
ENCRYPTION_KEY=change-me-to-a-32-char-hex-string

# Service-specific JWT overrides (optional, falls back to JWT_SECRET)
# OF_JWT_SECRET=open-finance-specific-secret

# ─── Pix / Open Finance ───────────────────────────────────────────────

PIX_API_BASE_URL=http://localhost:3001
PIX_CERT_PATH=
PIX_CERT_KEY_PATH=
PIX_CLIENT_ID=
PIX_CLIENT_SECRET=

OPEN_FINANCE_API_BASE_URL=http://localhost:3005

# ─── NFSe ─────────────────────────────────────────────────────────────

NFSE_API_BASE_URL=http://localhost:3006
NFSE_MUNICIPIO=SAO_PAULO
NFSE_CERT_PATH=
NFSE_CERT_KEY_PATH=

# ─── Report System ────────────────────────────────────────────────────

REPORT_EXPORT_DIR=./exports
REPORT_SCHEDULE=0 0 * * *
REPORT_RETENTION_DAYS=90

# ─── Rate Limiting ────────────────────────────────────────────────────

LEAKY_BUCKET_CAPACITY=100
LEAKY_BUCKET_REFILL_RATE=10
LEAKY_BUCKET_REFILL_INTERVAL_MS=1000

# ─── Frontend ─────────────────────────────────────────────────────────

VITE_API_BASE_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
