<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 400" fill="none">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="800" y2="400" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#0f172a"/>
      <stop offset="100%" stop-color="#1e3a5f"/>
    </linearGradient>
  </defs>
  <rect width="800" height="400" fill="url(#bg)"/>
  <rect x="40" y="60" width="160" height="80" rx="12" fill="#0077B5" opacity="0.9"/>
  <text x="120" y="100" font-family="system-ui, -apple-system, sans-serif" font-size="28" font-weight="700" fill="white" text-anchor="middle">BC</text>
  <text x="120" y="125" font-family="system-ui, -apple-system, sans-serif" font-size="12" fill="rgba(255,255,255,0.8)" text-anchor="middle">Banking Challenges</text>
  <circle cx="350" cy="120" r="40" fill="#3b82f6" opacity="0.3"/>
  <circle cx="350" cy="120" r="20" fill="#3b82f6" opacity="0.6"/>
  <text x="350" y="126" font-family="system-ui, sans-serif" font-size="18" fill="white" text-anchor="middle">SPI</text>
  <circle cx="500" cy="100" r="35" fill="#10b981" opacity="0.3"/>
  <circle cx="500" cy="100" r="17" fill="#10b981" opacity="0.6"/>
  <text x="500" y="106" font-family="system-ui, sans-serif" font-size="14" fill="white" text-anchor="middle">DICT</text>
  <circle cx="630" cy="130" r="45" fill="#f59e0b" opacity="0.3"/>
  <circle cx="630" cy="130" r="22" fill="#f59e0b" opacity="0.6"/>
  <text x="630" y="136" font-family="system-ui, sans-serif" font-size="14" fill="white" text-anchor="middle">ISO 8583</text>
  <line x1="200" y1="100" x2="310" y2="120" stroke="#3b82f6" stroke-width="2" opacity="0.4"/>
  <line x1="390" y1="120" x2="465" y2="100" stroke="#10b981" stroke-width="2" opacity="0.4"/>
  <line x1="535" y1="100" x2="585" y2="130" stroke="#f59e0b" stroke-width="2" opacity="0.4"/>
  <text x="400" y="280" font-family="system-ui, -apple-system, sans-serif" font-size="32" font-weight="700" fill="white" text-anchor="middle">14 Desafios Técnicos</text>
  <text x="400" y="320" font-family="system-ui, -apple-system, sans-serif" font-size="16" fill="rgba(255,255,255,0.7)" text-anchor="middle">SPI · DICT · ISO 8583 · Open Finance · GraphQL · Go</text>
  <text x="400" y="360" font-family="system-ui, -apple-system, sans-serif" font-size="14" fill="rgba(255,255,255,0.5)" text-anchor="middle">TypeScript · Go · Docker · MongoDB · PostgreSQL · Redis</text>
</svg>
